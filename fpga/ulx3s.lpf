# ulx3s.lpf — CORDIC-1 gate-level twin on the ULX3S 85F.
# Sites from the official ulx3s_v20 constraints, same subset the
# TinyRV32 and cartridge harnesses use.

LOCATE COMP "clk_25mhz" SITE "G2";
IOBUF  PORT "clk_25mhz" PULLMODE=NONE IO_TYPE=LVCMOS33;
FREQUENCY PORT "clk_25mhz" 25 MHZ;

LOCATE COMP "btn[0]" SITE "D6";
LOCATE COMP "btn[1]" SITE "R1";
LOCATE COMP "btn[2]" SITE "T1";
LOCATE COMP "btn[3]" SITE "R18";
LOCATE COMP "btn[4]" SITE "V1";
LOCATE COMP "btn[5]" SITE "U1";
LOCATE COMP "btn[6]" SITE "H16";
IOBUF PORT "btn[0]" PULLMODE=UP   IO_TYPE=LVCMOS33;
IOBUF PORT "btn[1]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "btn[2]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "btn[3]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "btn[4]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "btn[5]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "btn[6]" PULLMODE=DOWN IO_TYPE=LVCMOS33;

# SW1..SW4 = frequency code bits 0..3
LOCATE COMP "sw[0]" SITE "E8";
LOCATE COMP "sw[1]" SITE "D8";
LOCATE COMP "sw[2]" SITE "D7";
LOCATE COMP "sw[3]" SITE "E7";
IOBUF PORT "sw[0]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "sw[1]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "sw[2]" PULLMODE=DOWN IO_TYPE=LVCMOS33;
IOBUF PORT "sw[3]" PULLMODE=DOWN IO_TYPE=LVCMOS33;

LOCATE COMP "led[0]" SITE "B2";
LOCATE COMP "led[1]" SITE "C2";
LOCATE COMP "led[2]" SITE "C1";
LOCATE COMP "led[3]" SITE "D2";
LOCATE COMP "led[4]" SITE "D1";
LOCATE COMP "led[5]" SITE "E2";
LOCATE COMP "led[6]" SITE "E1";
LOCATE COMP "led[7]" SITE "H3";
IOBUF PORT "led[0]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[1]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[2]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[3]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[4]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[5]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[6]" IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "led[7]" IO_TYPE=LVCMOS33 DRIVE=4;

# J1 header: GP0 = sigma-delta sine (Audio Pmod / RC), GP1 = square sync
LOCATE COMP "pmod_gp[0]" SITE "B11";
LOCATE COMP "pmod_gp[1]" SITE "A10";
LOCATE COMP "pmod_gp[2]" SITE "A9";
LOCATE COMP "pmod_gp[3]" SITE "B9";
LOCATE COMP "pmod_gn[0]" SITE "C11";
LOCATE COMP "pmod_gn[1]" SITE "A11";
LOCATE COMP "pmod_gn[2]" SITE "B10";
LOCATE COMP "pmod_gn[3]" SITE "C10";
IOBUF PORT "pmod_gp[0]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "pmod_gp[1]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "pmod_gp[2]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "pmod_gp[3]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "pmod_gn[0]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "pmod_gn[1]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "pmod_gn[2]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;
IOBUF PORT "pmod_gn[3]" PULLMODE=NONE IO_TYPE=LVCMOS33 DRIVE=4;

LOCATE COMP "wifi_gpio0" SITE "L2";
IOBUF PORT "wifi_gpio0" PULLMODE=UP IO_TYPE=LVCMOS33;
